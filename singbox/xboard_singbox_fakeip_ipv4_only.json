        "domain": [
          "captive.apple.com",
          "seed-sequoia.siri.apple.com",
          "sequoia.apple.com",
          "www.baidu.com"
        ],
        "action": "route",
        "server": "dns_direct"
      },
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "dns_direct"
      },
      {
        "clash_mode": "Global",
        "action": "route",
        "server": "dns_fakeip"
      },
      {
        "query_type": [
          "HTTPS",
          "SVCB"
        ],
        "action": "reject"
      },
      {
        "query_type": [
          "A",
          "AAAA"
        ],
        "action": "route",
        "server": "dns_fakeip"
      }
    ],
    "final": "dns_proxy",
    "strategy": "ipv4_only"
  },
  "experimental": {
    "cache_file": {
      "enabled": true,
      "path": "cache.db",
      "store_fakeip": true
