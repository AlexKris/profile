{
  "log": {
    "disabled": false,
    "level": "info",
    "timestamp": true
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_proxy",
        "type": "https",
        "server": "1.1.1.1",
        "path": "/dns-query",
        "detour": "Proxy"
      },
      {
        "tag": "dns_direct",
        "type": "https",
        "server": "223.5.5.5",
        "path": "/dns-query"
      },
      {
        "tag": "dns_local",
        "type": "local"
      },
      {
        "tag": "dns_fakeip",
        "type": "fakeip",
        "inet4_range": "198.18.0.0/15"
      }
    ],
    "rules": [
      {
        "domain_suffix": [
          "cloudflare-ech.com"
        ],
        "action": "route",
        "server": "dns_direct"
      },
      {
        "rule_set": [
          "geosite-cn"
        ],
        "action": "route",
        "server": "dns_direct"
      },
      {
        "query_type": [
          "PTR"
        ],
        "domain_suffix": [
          "in-addr.arpa",
          "ip6.arpa"
        ],
        "action": "reject"
      },
      {
        "query_type": [
          "SOA"
        ],
        "domain": [
          "local"
        ],
        "action": "reject"
      },
      {
        "rule_set": [
          "geosite-private"
        ],
        "action": "route",
        "server": "dns_local"
      },
      {
        "domain": [
          "dns.msftncsi.com",
          "stun.l.google.com",
          "stun.syncthing.net",
          "lancache.steamcontent.com"
        ],
        "domain_suffix": [
          "msftconnecttest.com",
          "msftncsi.com",
          "srv.nintendo.net",
          "stun.playstation.net",
          "turn.twilio.com",
          "stun.twilio.com",
