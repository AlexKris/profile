    },
    {
      "tag": "RFCEmby",
      "type": "selector",
      "outbounds": [],
      "include": "(?=.*(?:🇭🇰|🇯🇵|🇸🇬|HK|JP|SG))(?=.*(?:RFC|Jinx))"
    },
    {
      "tag": "AIGC",
      "type": "selector",
      "outbounds": [],
      "include": "(?=.*(?:🇨🇳|🇯🇵|🇸🇬|🇺🇸|🇬🇧|TW|JP|SG|US|英国))(?=.*(?:SoftBank|Nuro|Ucom|IIJ|Starlink|ATT|Hawaii|家宽))"
